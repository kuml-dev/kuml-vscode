{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "kUML Script",
  "scopeName": "source.kuml",
  "fileTypes": ["kuml.kts"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#annotations" },
    { "include": "#kuml-dsl" },
    { "include": "#kotlin-keywords" },
    { "include": "#kotlin-types" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.documentation.kuml",
          "begin": "/\\*\\*",
          "end": "\\*/",
          "patterns": [
            {
              "name": "storage.type.class.kdoc.kuml",
              "match": "@(param|return|throws|see|since|sample|property|constructor|receiver|author)\\b"
            }
          ]
        },
        {
          "name": "comment.block.kuml",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.line.double-slash.kuml",
          "begin": "//",
          "end": "$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.kuml",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            { "include": "#string-interpolation" }
          ]
        },
        {
          "name": "string.quoted.double.kuml",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.kuml",
              "match": "\\\\(n|r|t|b|\\\\|\"|'|\\$|u[0-9a-fA-F]{4})"
            },
            { "include": "#string-interpolation" }
          ]
        },
        {
          "name": "string.quoted.single.kuml",
          "match": "'(\\\\(n|r|t|b|\\\\|\"|'|u[0-9a-fA-F]{4})|.)'"
        }
      ]
    },
    "string-interpolation": {
      "patterns": [
        {
          "name": "meta.template.expression.kuml",
          "begin": "\\$\\{",
          "end": "\\}",
          "beginCaptures": { "0": { "name": "punctuation.section.embedded.begin.kuml" } },
          "endCaptures":   { "0": { "name": "punctuation.section.embedded.end.kuml" } },
          "patterns": [ { "include": "$self" } ]
        },
        {
          "name": "meta.template.expression.kuml",
          "match": "\\$[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "storage.modifier.annotation.kuml",
          "match": "@(file:|delegate:|field:|property:|get:|set:|receiver:|param:|setparam:|sparam:)?[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "kuml-dsl": {
      "patterns": [
        {
          "comment": "kUML top-level DSL entry points (Diagram + Model)",
          "name": "support.function.kuml.dsl.toplevel",
          "match": "\\b(diagram|umlModel|c4Model|classDiagram|objectDiagram|packageDiagram|componentDiagram|deploymentDiagram|useCaseDiagram|sequenceDiagram|communicationDiagram|stateDiagram|stateMachine|activityDiagram|profileDiagram|timingDiagram|interactionOverviewDiagram|compositeStructureDiagram|systemContextDiagram|containerDiagram|dynamicDiagram|systemLandscapeDiagram)\\b"
        },
        {
          "comment": "UML DSL builders (classifier-level)",
          "name": "support.function.kuml.dsl.uml",
          "match": "\\b(classOf|interfaceOf|enumOf|abstractClassOf|dataClassOf|package|`package`|association|generalization|realization|dependency|aggregation|composition|usage|nesting|constraint|stereotype|appliedStereotype|profile|applyProfile|attribute|operation|parameter|state|substate|initial|final|choice|fork|join|transition|trigger|guard|effect|entry|exit|doActivity|component|port|signal|receiveSignal|sendSignal|actor|useCase|extend|include|node|artifact|deployment|message|lifeline|fragment|interaction|collaboration|activity|action|controlFlow|objectFlow|decision|merge|partition)\\b"
        },
        {
          "comment": "C4 DSL builders",
          "name": "support.function.kuml.dsl.c4",
          "match": "\\b(person|softwareSystem|container|relationship|containerInstance|componentInstance|softwareSystemInstance|deploymentNode|infrastructureNode|enterprise|group|tag|style|technology)\\b"
        },
        {
          "comment": "kUML metamodel enum constants (UmlMetaclass.*, Visibility.*, AggregationKind.* in defaultImports)",
          "name": "support.constant.kuml.metamodel",
          "match": "\\b(Class|Interface|Enum|Property|Operation|Parameter|StateMachine|State|Pseudostate|Transition|Component|Port|Signal|Reception|Activity|Action|Public|Private|Protected|Package|None|Shared|Composite|Aggregation|Composition|INITIAL|FINAL|SHALLOW_HISTORY|DEEP_HISTORY|CHOICE|FORK|JOIN|JUNCTION|ENTRY_POINT|EXIT_POINT|TERMINATE)\\b"
        }
      ]
    },
    "kotlin-keywords": {
      "patterns": [
        {
          "name": "keyword.control.kuml",
          "match": "\\b(if|else|when|for|while|do|return|break|continue|throw|try|catch|finally|in|is|as)\\b"
        },
        {
          "name": "keyword.declaration.kuml",
          "match": "\\b(fun|val|var|class|interface|object|enum|sealed|data|inline|noinline|crossinline|tailrec|operator|infix|external|abstract|open|final|override|companion|init|constructor|by|delegate|where|typealias|package|import)\\b"
        },
        {
          "name": "storage.modifier.kuml",
          "match": "\\b(public|private|protected|internal|lateinit|const|reified|vararg|out|in|suspend|expect|actual)\\b"
        },
        {
          "name": "constant.language.kuml",
          "match": "\\b(true|false|null|this|super|Unit|Nothing)\\b"
        }
      ]
    },
    "kotlin-types": {
      "patterns": [
        {
          "name": "support.type.primitive.kuml",
          "match": "\\b(Int|Long|Short|Byte|Float|Double|Boolean|Char|String|Any|Nothing|Unit|Array|List|Map|Set|MutableList|MutableMap|MutableSet|Pair|Triple|Number)\\b"
        },
        {
          "comment": "Type-like identifiers (PascalCase) used in declarations",
          "name": "entity.name.type.kuml",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.kuml",
          "match": "\\b0[xX][0-9a-fA-F_]+[uUlL]?\\b"
        },
        {
          "name": "constant.numeric.binary.kuml",
          "match": "\\b0[bB][01_]+[uUlL]?\\b"
        },
        {
          "name": "constant.numeric.float.kuml",
          "match": "\\b\\d[\\d_]*\\.\\d[\\d_]*([eE][+-]?\\d+)?[fFdD]?\\b"
        },
        {
          "name": "constant.numeric.decimal.kuml",
          "match": "\\b\\d[\\d_]*[uUlLfFdD]?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.kuml",
          "match": "(\\+=|-=|\\*=|/=|%=|=)"
        },
        {
          "name": "keyword.operator.comparison.kuml",
          "match": "(==|!=|<=|>=|<|>|===|!==)"
        },
        {
          "name": "keyword.operator.arithmetic.kuml",
          "match": "(\\+|-|\\*|/|%|\\+\\+|--)"
        },
        {
          "name": "keyword.operator.logical.kuml",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.range.kuml",
          "match": "(\\.\\.|until|downTo|step)"
        },
        {
          "name": "keyword.operator.elvis.kuml",
          "match": "(\\?:|\\?\\.|!!)"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "comment": "Backtick-escaped identifier (Kotlin syntax for keyword-as-name)",
          "name": "entity.name.function.escaped.kuml",
          "match": "`[^`]+`"
        },
        {
          "comment": "Function call (identifier directly followed by '(' or '{')",
          "name": "entity.name.function.call.kuml",
          "match": "\\b[a-z_][A-Za-z0-9_]*(?=\\s*[\\({])"
        }
      ]
    }
  }
}
