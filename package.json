{
  "name": "kuml-vscode",
  "displayName": "kUML",
  "description": "Syntax highlighting, snippets, LSP diagnostics/completion, and live-preview rendering for kUML diagram scripts (*.kuml.kts).",
  "version": "0.2.0",
  "publisher": "kuml-dev",
  "license": "Apache-2.0",
  "homepage": "https://kuml.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/kuml-dev/kuml-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/kuml-dev/kuml-vscode/issues"
  },
  "icon": "icons/kuml-marketplace.png",
  "_comment_icon": "PNG required by vsce (SVGs are rejected). Generated from icons/kuml-script-dark.svg.",
  "categories": [
    "Programming Languages",
    "Snippets",
    "Visualization"
  ],
  "keywords": [
    "kuml",
    "uml",
    "c4",
    "diagram",
    "kotlin-script"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:kuml"
  ],
  "contributes": {
    "languages": [
      {
        "id": "kuml",
        "aliases": ["kUML", "kuml"],
        "extensions": [".kuml.kts"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/kuml-script-light.svg",
          "dark": "./icons/kuml-script-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "kuml",
        "scopeName": "source.kuml",
        "path": "./syntaxes/kuml.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "kuml",
        "path": "./snippets/kuml.json"
      }
    ],
    "commands": [
      {
        "command": "kuml.renderToSvg",
        "title": "kUML: Render to SVG",
        "category": "kUML"
      },
      {
        "command": "kuml.showPreview",
        "title": "kUML: Open Live Preview",
        "category": "kUML"
      },
      {
        "command": "kuml.restartServer",
        "title": "kUML: Restart Language Server",
        "category": "kUML"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceLangId == kuml",
          "command": "kuml.renderToSvg",
          "group": "navigation"
        },
        {
          "when": "resourceLangId == kuml",
          "command": "kuml.showPreview",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "when": "resourceLangId == kuml",
          "command": "kuml.renderToSvg",
          "group": "kuml@1"
        },
        {
          "when": "resourceLangId == kuml",
          "command": "kuml.showPreview",
          "group": "kuml@2"
        }
      ],
      "commandPalette": [
        {
          "command": "kuml.renderToSvg",
          "when": "resourceLangId == kuml"
        },
        {
          "command": "kuml.showPreview",
          "when": "resourceLangId == kuml"
        },
        {
          "command": "kuml.restartServer",
          "when": "resourceLangId == kuml"
        }
      ]
    },
    "configuration": {
      "title": "kUML",
      "properties": {
        "kuml.cliPath": {
          "type": "string",
          "default": "kuml",
          "description": "Path to the kUML CLI executable. Defaults to `kuml` (resolved on PATH). Override if the CLI is installed in a non-standard location."
        },
        "kuml.theme": {
          "type": "string",
          "default": "kuml",
          "description": "Default theme passed to `kuml render --theme`. Any name registered via the ThemeRegistry (e.g. plain, kuml, elegant, playful)."
        },
        "kuml.format": {
          "type": "string",
          "enum": ["svg", "png"],
          "default": "svg",
          "description": "Render output format used by the `kUML: Render to SVG` command. PNG is opened in the default OS viewer; SVG is opened in a VS Code preview tab."
        },
        "kuml.lspPath": {
          "type": "string",
          "default": "",
          "description": "Explicit path to the `kuml-lsp` language server launcher. Empty resolves it automatically: PATH, Homebrew (`/opt/homebrew/bin`, `/usr/local/bin`), `~/.local/bin`, then a local Gradle build (`kuml-language-server/build/install/kuml-lsp/bin`) — same order as the `kuml` CLI."
        },
        "kuml.serverUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL of a running `kuml serve` instance (e.g. http://127.0.0.1:8080) used by the live preview for rendering. Empty makes the preview shell out to `kuml render` instead."
        },
        "kuml.diagnostics.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable push diagnostics (parse/validation errors) from the kUML language server."
        },
        "kuml.diagnostics.debounceMs": {
          "type": "number",
          "default": 300,
          "minimum": 0,
          "description": "Debounce interval (milliseconds) between an edit and the language server re-validating the document."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -p . --watch",
    "test": "node --test --enable-source-maps out/test/*.test.js",
    "package": "vsce package",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^3.0.0"
  }
}
